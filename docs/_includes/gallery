{% if page.gallery %}
<figure class="{{ include.class }}">
  {% for img in page.gallery %}
    {% if img.image %}
      <a href="{{ img.image | relative_url }}">
        <img src="{{ img.image | relative_url }}"
             alt="{{ img.alt }}"
             {% if img.title %}title="{{ img.title }}"{% endif %}>
      </a>
      {% if img.caption %}
        <figcaption>{{ img.caption }}</figcaption>
      {% endif %}
    {% endif %}
  {% endfor %}
</figure>
{% endif %}
